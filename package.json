		"@types/d3": "^7.4.0",
		"svelte": "^5.51.0",
		"svelte-check": "^4.4.2",
		"tailwindcss": "^4.0.0",
		"typescript": "^5.9.3",
		"vite": "^7.3.1",
		"vitest": "^4.0.18"
	},
	"dependencies": {
		"@anthropic-ai/sdk": "^0.39.0",
		"@opentelemetry/api": "1.9.0",
		"@opentelemetry/context-async-hooks": "2.5.1",
		"@opentelemetry/core": "2.5.1",
		"@opentelemetry/resources": "2.5.1",
		"@opentelemetry/sdk-trace-base": "2.5.1",
